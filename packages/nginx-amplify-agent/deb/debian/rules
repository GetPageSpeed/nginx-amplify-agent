#!/usr/bin/make -f

INSTALLDIR = $(CURDIR)/debian/nginx-amplify-agent

%:
	dh $@ --with python3

override_dh_auto_configure:
	# No configuration needed - using custom build

override_dh_auto_build:
	python3 -m pip install --upgrade --target=amplify --no-compile -r %%REQUIREMENTS%%
	python3 setup.py build

override_dh_auto_install:
	python3 setup.py install --prefix=/usr --install-scripts=/usr/bin --root=$(INSTALLDIR) --no-compile

override_dh_installinit:
	dh_installinit -pnginx-amplify-agent --no-stop-on-upgrade --no-start --name=amplify-agent -- defaults 99 01

override_dh_installsystemd:
	dh_installsystemd -pnginx-amplify-agent --name=amplify-agent --no-start amplify-agent.service

# /etc/amplify-agent/agent.conf.default is a build-time template consumed by
# install.sh (sed'd into /etc/amplify-agent/agent.conf), not a user-editable
# config. dh_installdeb auto-registers every file under /etc/ as a dpkg
# conffile, which causes install.sh to fail with "can't find
# /etc/amplify-agent/agent.conf.default" after a remove + rm + reinstall
# cycle. Strip the auto-registration here; legacy installs are migrated
# via debian/nginx-amplify-agent.maintscript (rm_conffile).
override_dh_installdeb:
	dh_installdeb
	if [ -f $(INSTALLDIR)/DEBIAN/conffiles ]; then \
		sed -i '\|^/etc/amplify-agent/agent.conf.default$$|d' $(INSTALLDIR)/DEBIAN/conffiles; \
	fi

override_dh_builddeb:
	dh_builddeb -- -Zxz

override_dh_auto_test:
	# Skip tests

override_dh_auto_clean:
	rm -rf build
	rm -rf *.egg-info
	find amplify/ -mindepth 1 -maxdepth 1 -type d -not -name agent -and -not -name ext -exec rm -rf {} \; 2>/dev/null || true
